{
  "name": "web-request-analysis-tool",
  "version": "1.2.1",
  "description": "网页网络请求分析工具 — 捕获页面所有请求的 URL、IP、端口与成功/失败状态",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "dist": "electron-builder --win"
  },
  "keywords": [
    "network",
    "analyzer",
    "electron"
  ],
  "author": "Web Request Analysis Tool",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.youqian.webrequesttool",
    "productName": "WebRequestAnalysisTool",
    "copyright": "Copyright © YouQian Tech",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
